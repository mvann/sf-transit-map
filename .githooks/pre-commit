#!/usr/bin/env bash
# Prevent committing files that match sensitive patterns.

BLOCKED_PATTERNS=(.env .env.local .env.production .env.*)

STAGED_FILES=$(git diff --cached --name-only)

for file in $STAGED_FILES; do
  for pattern in "${BLOCKED_PATTERNS[@]}"; do
    case "$file" in
      $pattern)
        echo "ERROR: Refusing to commit '$file' — matches blocked pattern '$pattern'"
        echo "If this is intentional, use --no-verify (not recommended)."
        exit 1
        ;;
    esac
  done
done
